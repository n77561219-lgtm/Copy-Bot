# ─────────────────────────────────────────────────────────────
# Telegram
# ─────────────────────────────────────────────────────────────

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Разрешённые пользователи (твой user_id через запятую)
# Узнать свой ID: написать @userinfobot
TELEGRAM_ALLOWED_USERS=

# ─────────────────────────────────────────────────────────────
# OpenRouter  →  https://openrouter.ai/keys
# ─────────────────────────────────────────────────────────────

OPENROUTER_API_KEY=sk-or-v1-your_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─────────────────────────────────────────────────────────────
# Модели
# ─────────────────────────────────────────────────────────────

MODEL_HAIKU=anthropic/claude-3-5-haiku
MODEL_SONNET=anthropic/claude-3-5-sonnet

# ─────────────────────────────────────────────────────────────
# База данных PostgreSQL
# ─────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://copybot_user:copybot_pass_2026@localhost:5432/copybot

# ─────────────────────────────────────────────────────────────
# Apify (для поиска трендов)
# ─────────────────────────────────────────────────────────────

APIFY_TOKEN=your_apify_token_here
